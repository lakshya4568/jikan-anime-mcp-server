{
  "name": "jikan-anime-mcp-server",
  "version": "1.0.1",
  "description": "MCP server for the Jikan API - Unofficial MyAnimeList REST API for anime, manga, characters & more",
  "main": "dist/index.js",
  "bin": {
    "jikan-anime-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs');const p='dist/index.js';if(fs.existsSync(p)){const c=fs.readFileSync(p,'utf8');if(!c.startsWith('#!/usr/bin/env node')) fs.writeFileSync(p,'#!/usr/bin/env node\\n'+c);}\"",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "anime",
    "manga",
    "jikan",
    "myanimelist"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.1",
    "axios": "^1.7.9",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
